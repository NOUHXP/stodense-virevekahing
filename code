                            <h5 class="text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-4">Neural Architecture</h5>
                            <p class="text-xs text-slate-400 leading-relaxed">Utilizing large-context reasoning to cross-reference multiple date cycles and identify anomalies in subject behavior.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- PAGE: HISTORY -->
