<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Presence Pro | AI Terminal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        
        :root {
            --primary: #6366f1;
            --sidebar-w: 260px;
            --transition-fast: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            overflow: hidden;
            transition: background-color 0.3s ease;
        }

        body.dark { background-color: #020617; color: #f8fafc; }
        body.light { background-color: #f8fafc; color: #0f172a; }

        .bg-mesh {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1;
            opacity: 0.15;
            filter: blur(120px);
            pointer-events: none;
        }

        .blob {
            position: absolute;
            width: 600px; height: 600px;
            background: linear-gradient(135deg, var(--primary), #0ea5e9);
            border-radius: 50%;
            animation: drift 25s infinite alternate ease-in-out;
        }

        @keyframes drift {
            0% { transform: translate(-20%, -20%) scale(1); }
            100% { transform: translate(20%, 20%) scale(1.2); }
        }

        .glass {
            backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        body.dark .glass { background: rgba(15, 23, 42, 0.6); }
        body.light .glass { background: rgba(255, 255, 255, 0.7); border-color: rgba(0,0,0,0.05); }

        .nav-link {
            transition: var(--transition-fast);
            border-radius: 12px;
            color: #94a3b8;
            cursor: pointer;
        }
        .nav-link:hover { background: rgba(99, 102, 241, 0.1); color: var(--primary); }
        .nav-link.active { background: var(--primary) !important; color: white !important; box-shadow: 0 8px 20px -4px rgba(99, 102, 241, 0.4); }

        .page { display: none; opacity: 0; transform: translateY(10px); }
        .page.active { display: block; animation: fadeIn 0.4s ease-out forwards; }

        @keyframes fadeIn { to { opacity: 1; transform: translateY(0); } }

        .btn-primary { background: var(--primary); transition: var(--transition-fast); }
        .btn-primary:hover { filter: brightness(1.1); transform: translateY(-1px); }

        .loader {
            width: 20px; height: 20px;
            border: 2.5px solid currentColor;
            border-bottom-color: transparent;
            border-radius: 50%;
            display: inline-block;
            animation: rotation 0.8s linear infinite;
        }

        @keyframes rotation { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

        /* AI CORE CHAT STYLES */
        .chat-container {
            height: 450px;
            display: flex;
            flex-direction: column;
        }
        .message-bubble {
            max-width: 80%;
            padding: 1rem;
            border-radius: 1.25rem;
            margin-bottom: 0.75rem;
            font-size: 0.875rem;
            line-height: 1.5;
        }
        .message-ai { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.05); border-top-left-radius: 0; }
        .message-user { background: var(--primary); color: white; border-top-right-radius: 0; align-self: flex-end; }
        
        .voice-bars {
            display: flex;
            align-items: center;
            gap: 2px;
            height: 16px;
        }
        .bar {
            width: 2px;
            background: var(--primary);
            border-radius: 10px;
            animation: soundWave 1s infinite ease-in-out;
        }
        @keyframes soundWave {
            0%, 100% { height: 4px; }
            50% { height: 16px; }
        }

        /* CUSTOM SLIDER */
        input[type=range] {
            -webkit-appearance: none;
            background: transparent;
        }
        input[type=range]::-webkit-slider-runnable-track {
            width: 100%;
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: 10px;
        }
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 18px;
            width: 18px;
            border-radius: 50%;
            background: var(--primary);
            margin-top: -6px;
            cursor: pointer;
            box-shadow: 0 0 10px var(--primary);
        }
    </style>
</head>
<body class="dark">

    <div class="bg-mesh">
        <div id="glow-blob" class="blob"></div>
    </div>

    <!-- 🔒 LOGIN -->
    <div id="login-overlay" class="fixed inset-0 z-[100] flex items-center justify-center bg-slate-950">
        <div class="w-full max-sm:mx-4 max-w-sm p-10 glass rounded-[2.5rem] text-center shadow-2xl">
            <div class="w-16 h-16 bg-indigo-600 rounded-2xl mx-auto flex items-center justify-center text-white mb-6 shadow-xl">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            </div>
            <h1 class="text-2xl font-black tracking-tight">Access Terminal</h1>
            <p class="text-slate-500 text-[10px] font-black uppercase tracking-[0.3em] mt-2 mb-6">SECURE AI LINK V9</p>
            <form id="login-form" class="space-y-4">
                <input type="password" id="auth-pass" maxlength="4" placeholder="••••" class="w-full p-5 rounded-2xl text-center text-4xl tracking-widest font-black bg-white/5 border-none outline-none focus:ring-2 ring-indigo-500">
                <button type="submit" id="login-btn" class="w-full btn-primary p-5 rounded-2xl font-bold uppercase tracking-widest text-xs text-white">Unlock</button>
            </form>
            <p id="auth-error" class="text-red-500 text-[10px] font-black mt-4 hidden uppercase tracking-widest">Invalid Protocol</p>
        </div>
    </div>

    <!-- 📱 APP FRAMEWORK -->
    <div id="main-interface" class="hidden flex h-screen overflow-hidden">
        
        <aside class="sidebar glass w-[260px] h-screen flex flex-col p-6 border-r border-white/5">
            <div class="mb-10 flex items-center gap-3 px-2">
                <div class="w-9 h-9 bg-indigo-600 rounded-xl flex items-center justify-center text-white font-black">P</div>
                <span class="text-xl font-black tracking-tighter">Presence<span class="text-indigo-500">Pro</span></span>
            </div>

            <nav class="flex-1 space-y-1">
                <button onclick="changePage('home')" id="btn-home" class="nav-link w-full text-left p-3.5 flex items-center gap-3 active">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 4v16m8-8H4"/></svg>
                    <span class="font-bold text-[11px] uppercase tracking-widest">Register</span>
                </button>
                <button onclick="changePage('list')" id="btn-list" class="nav-link w-full text-left p-3.5 flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
                    <span class="font-bold text-[11px] uppercase tracking-widest">Data Vault</span>
                </button>
                <button onclick="changePage('ai')" id="btn-ai" class="nav-link w-full text-left p-3.5 flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    <span class="font-bold text-[11px] uppercase tracking-widest">AI Terminal</span>
                </button>
                <button onclick="changePage('settings')" id="btn-settings" class="nav-link w-full text-left p-3.5 flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0012 18.75c-1.03 0-1.9-.4-2.593-.903l-.547-.547z"/></svg>
                    <span class="font-bold text-[11px] uppercase tracking-widest">Lighting</span>
                </button>
            </nav>

            <div class="pt-6 border-t border-white/5 space-y-4">
                <div class="p-3.5 glass rounded-2xl flex items-center justify-between">
                    <span class="text-[10px] font-black uppercase opacity-40">Dark Mode</span>
                    <div class="w-10 h-6 bg-slate-800 rounded-full relative cursor-pointer flex items-center px-1" onclick="toggleTheme()">
                        <div id="theme-thumb" class="w-4 h-4 bg-white rounded-full transition-transform translate-x-4"></div>
                    </div>
                </div>
            </div>
        </aside>

        <main class="flex-1 p-12 overflow-y-auto relative">
            <header class="flex justify-between items-start mb-12">
                <div>
                    <h2 class="text-4xl font-black tracking-tight" id="active-header">Registration</h2>
                    <p class="text-slate-500 font-bold mt-1 uppercase text-[10px] tracking-widest" id="header-desc">Temporary Memory Bridge</p>
                </div>
                <div class="glass px-6 py-3 rounded-2xl font-mono text-indigo-400 font-black text-lg shadow-lg border-indigo-500/10" id="live-clock">00:00:00</div>
            </header>

            <!-- PAGE: HOME -->
            <section id="page-home" class="page active">
                <div class="max-w-md glass p-10 rounded-[2.5rem] shadow-xl">
                    <form id="add-form" class="space-y-8">
                        <div>
                            <label class="block text-[10px] font-black text-slate-500 uppercase mb-3 tracking-widest">Subject ID</label>
                            <input type="text" id="inp-name" required placeholder="Full Name" class="w-full p-5 rounded-2xl font-bold bg-white/5 border-none outline-none focus:ring-2 ring-indigo-500">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-500 uppercase mb-3 tracking-widest">Age Reference</label>
                            <input type="number" id="inp-age" required placeholder="Age" class="w-full p-5 rounded-2xl font-bold bg-white/5 border-none outline-none focus:ring-2 ring-indigo-500">
                        </div>
                        <button type="submit" class="w-full btn-primary p-6 rounded-2xl text-sm font-black uppercase tracking-widest text-white">Log to Memory</button>
                    </form>
                </div>
            </section>

            <!-- PAGE: LIST (One-page Data Management) -->
            <section id="page-list" class="page">
                <div class="space-y-8">
                    <!-- Management Bar -->
                    <div class="flex flex-wrap gap-4 items-center">
                        <button onclick="downloadData()" class="px-6 py-4 glass rounded-2xl hover:bg-white/5 flex items-center gap-3 transition-all">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                            <span class="font-black text-[10px] uppercase tracking-[0.2em]">Export (Save)</span>
                        </button>
                        <button onclick="purgeAllData()" class="px-6 py-4 glass rounded-2xl hover:bg-red-500/10 flex items-center gap-3 transition-all group">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            <span class="font-black text-[10px] uppercase tracking-[0.2em] text-red-500">Purge All</span>
                        </button>
                        <div class="ml-auto glass px-6 py-4 rounded-2xl">
                             <span id="entry-count" class="text-[10px] font-mono text-indigo-400 font-bold uppercase tracking-widest">0 Sessions</span>
                        </div>
                    </div>

                    <!-- Entries Table -->
                    <div class="glass rounded-[2rem] overflow-hidden shadow-xl border border-white/5">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead class="bg-indigo-600/5 text-slate-500">
                                    <tr>
                                        <th class="p-6 font-black uppercase text-[9px] tracking-[0.3em]">Node Meta</th>
                                        <th class="p-6 font-black uppercase text-[9px] tracking-[0.3em]">Age</th>
                                        <th class="p-6 text-right font-black uppercase text-[9px] tracking-[0.3em]">Protocol</th>
                                    </tr>
                                </thead>
                                <tbody id="table-body"></tbody>
                            </table>
                        </div>
                        <div id="empty-state" class="p-20 text-center hidden">
                            <div class="text-slate-600 text-[10px] font-black uppercase tracking-widest">Memory Bank Empty</div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- PAGE: AI TERMINAL -->
            <section id="page-ai" class="page">
                <div class="max-w-4xl mx-auto">
                    <div class="glass p-1 rounded-[2.5rem] border border-indigo-500/10 shadow-xl overflow-hidden">
                        <div class="p-8 pb-4 flex items-center justify-between border-b border-white/5">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-lg shadow-indigo-600/20">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                </div>
                                <div>
                                    <h4 class="text-xl font-black tracking-tight">AI Core Link</h4>
                                    <div id="voice-indicator" class="voice-bars hidden mt-1">
                                        <div class="bar" style="animation-delay: 0.1s"></div>
                                        <div class="bar" style="animation-delay: 0.3s"></div>
                                        <div class="bar" style="animation-delay: 0.2s"></div>
                                        <div class="bar" style="animation-delay: 0.4s"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="chat-box" class="chat-container p-8 overflow-y-auto bg-slate-950/20">
                            <div class="message-bubble message-ai">
                                Neural link established. Memory-only mode active.
                            </div>
                        </div>

                        <div class="p-6 border-t border-white/5 bg-slate-950/40">
                            <form id="chat-form" class="flex gap-4">
                                <input type="text" id="chat-input" placeholder="Enter query..." class="flex-1 bg-white/5 border-none outline-none p-5 rounded-2xl font-bold focus:ring-2 ring-indigo-500 placeholder:text-slate-600">
                                <button type="submit" id="chat-send" class="btn-primary p-5 rounded-2xl flex items-center justify-center text-white px-8">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </section>

            <!-- PAGE: LIGHTING -->
            <section id="page-settings" class="page">
                <div class="max-w-2xl glass p-10 rounded-[2.5rem] shadow-xl">
                    <div class="space-y-12">
                        <div>
                            <div class="flex justify-between mb-4">
                                <label class="text-[10px] font-black uppercase tracking-widest text-slate-500">Ambiance Opacity</label>
                                <span id="glow-val" class="text-[10px] font-mono text-indigo-400">0.15</span>
                            </div>
                            <input type="range" min="0" max="0.5" step="0.01" value="0.15" class="w-full" id="light-intensity" oninput="updateLighting()">
                        </div>
                        
                        <div>
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-500 block mb-6">Neural Tint Protocol</label>
                            <div class="flex flex-wrap gap-6">
                                <button onclick="setTint('#6366f1')" class="group flex flex-col items-center gap-2">
                                    <div class="w-12 h-12 rounded-2xl bg-[#6366f1] border-4 border-white/5 group-hover:scale-110 transition-transform shadow-lg shadow-indigo-600/20"></div>
                                    <span class="text-[8px] font-black uppercase tracking-widest text-slate-500">Indigo</span>
                                </button>
                                <button onclick="setTint('#ec4899')" class="group flex flex-col items-center gap-2">
                                    <div class="w-12 h-12 rounded-2xl bg-[#ec4899] border-4 border-white/5 group-hover:scale-110 transition-transform shadow-lg shadow-pink-600/20"></div>
                                    <span class="text-[8px] font-black uppercase tracking-widest text-slate-500">Pulse</span>
                                </button>
                                <button onclick="setTint('#10b981')" class="group flex flex-col items-center gap-2">
                                    <div class="w-12 h-12 rounded-2xl bg-[#10b981] border-4 border-white/5 group-hover:scale-110 transition-transform shadow-lg shadow-emerald-600/20"></div>
                                    <span class="text-[8px] font-black uppercase tracking-widest text-slate-500">Synth</span>
                                </button>
                                <button onclick="setTint('#f59e0b')" class="group flex flex-col items-center gap-2">
                                    <div class="w-12 h-12 rounded-2xl bg-[#f59e0b] border-4 border-white/5 group-hover:scale-110 transition-transform shadow-lg shadow-amber-600/20"></div>
                                    <span class="text-[8px] font-black uppercase tracking-widest text-slate-500">Amber</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

        </main>
    </div>

    <!-- Alert Modal -->
    <div id="modal-container" class="fixed inset-0 z-[200] hidden flex items-center justify-center bg-black/80 backdrop-blur-md p-4">
        <div class="w-full max-w-sm glass p-10 rounded-[2.5rem] text-center border border-white/10 shadow-2xl">
            <h4 id="modal-title" class="text-xl font-black mb-3">Notice</h4>
            <p id="modal-body" class="text-slate-400 text-sm mb-8 leading-relaxed"></p>
            <div class="flex gap-4">
                <button onclick="closeModal()" class="flex-1 p-4 rounded-2xl font-black uppercase text-[10px] tracking-widest bg-white/5 hover:bg-white/10 transition-colors">Cancel</button>
                <button id="modal-confirm" class="flex-1 p-4 rounded-2xl font-black uppercase text-[10px] tracking-widest bg-red-600 text-white shadow-lg shadow-red-600/30">Proceed</button>
            </div>
        </div>
    </div>

    <script>
        // Use In-Memory state as requested (No Save/No Firestore)
        let memoryStore = [];
        let authUnlocked = false;
        const currentPass = "1234";
        const apiKey = "";

        // UI Helpers
        setInterval(() => {
            const clock = document.getElementById('live-clock');
            if (clock) clock.innerText = new Date().toLocaleTimeString();
        }, 1000);

        function toggleTheme() {
            const isDark = document.body.classList.toggle('dark');
            document.body.classList.toggle('light', !isDark);
            document.getElementById('theme-thumb').style.transform = isDark ? 'translateX(16px)' : 'translateX(0)';
        }

        function changePage(id) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-link').forEach(n => n.classList.remove('active'));
            document.getElementById(`page-${id}`).classList.add('active');
            document.getElementById(`btn-${id}`).classList.add('active');
            
            const titles = { home: 'Registration', list: 'Data Vault', ai: 'AI Terminal', settings: 'Lighting' };
            document.getElementById('active-header').innerText = titles[id];
            if (id === 'list') render();
        }

        // Lighting Engine
        function updateLighting() {
            const val = document.getElementById('light-intensity').value;
            document.querySelector('.bg-mesh').style.opacity = val;
            document.getElementById('glow-val').innerText = val;
        }

        function setTint(color) {
            document.documentElement.style.setProperty('--primary', color);
            document.getElementById('glow-blob').style.background = `linear-gradient(135deg, ${color}, #0ea5e9)`;
        }

        // Data Management (In-Memory)
        function downloadData() {
            if (memoryStore.length === 0) return;
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(memoryStore, null, 2));
            const dlAnchorElem = document.createElement('a');
            dlAnchorElem.setAttribute("href", dataStr);
            dlAnchorElem.setAttribute("download", `presence_export_${Date.now()}.json`);
            dlAnchorElem.click();
        }

        function purgeAllData() {
            showModal("Wipe Memory?", "This will clear all registered sessions in the current window.", () => {
                memoryStore = [];
                render();
                closeModal();
            });
        }

        function deleteEntry(id) {
            memoryStore = memoryStore.filter(e => e.id !== id);
            render();
        }

        function render() {
            const tbody = document.getElementById('table-body');
            const empty = document.getElementById('empty-state');
            document.getElementById('entry-count').innerText = `${memoryStore.length} Sessions`;

            if (memoryStore.length === 0) {
                tbody.innerHTML = '';
                empty.classList.remove('hidden');
                return;
            }

            empty.classList.add('hidden');
            tbody.innerHTML = memoryStore.map(s => `
                <tr class="border-b border-white/5 hover:bg-white/5 transition-colors group">
                    <td class="p-6">
                        <div class="font-bold text-sm text-slate-200">${s.name}</div>
                        <div class="text-[9px] text-slate-500 uppercase tracking-widest font-mono mt-1 opacity-60">REF: ${s.id}</div>
                    </td>
                    <td class="p-6 text-indigo-400 text-sm font-black mono">${s.age}</td>
                    <td class="p-6 text-right">
                        <button onclick="deleteEntry('${s.id}')" class="px-4 py-2 rounded-lg bg-red-500/10 text-red-500/50 hover:text-red-500 text-[10px] font-black uppercase tracking-widest transition-all">Remove</button>
                    </td>
                </tr>
            `).join('');
        }

        // Authentication
        document.getElementById('login-form').addEventListener('submit', (e) => {
            e.preventDefault();
            const input = document.getElementById('auth-pass').value;
            if (input === currentPass) {
                document.getElementById('login-overlay').style.display = 'none';
                document.getElementById('main-interface').classList.remove('hidden');
            } else {
                document.getElementById('auth-error').classList.remove('hidden');
            }
        });

        // CRUD
        document.getElementById('add-form').addEventListener('submit', (e) => {
            e.preventDefault();
            const name = document.getElementById('inp-name').value;
            const age = document.getElementById('inp-age').value;
            memoryStore.push({ id: Math.random().toString(36).substr(2, 9).toUpperCase(), name, age });
            document.getElementById('add-form').reset();
            changePage('list');
        });

        // AI Logic
        document.getElementById('chat-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const input = document.getElementById('chat-input');
            const val = input.value.trim();
            if (!val) return;

            const box = document.getElementById('chat-box');
            const uDiv = document.createElement('div');
            uDiv.className = "message-bubble message-user";
            uDiv.innerText = val;
            box.appendChild(uDiv);
            input.value = '';
            box.scrollTop = box.scrollHeight;

            try {
                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: val }] }],
                        systemInstruction: { parts: [{ text: "You are AI Core. Memory mode active. Keep responses brief." }] }
                    })
                });
                const data = await response.json();
                const aiText = data.candidates?.[0]?.content?.parts?.[0]?.text || "Signal lost.";
                const aDiv = document.createElement('div');
                aDiv.className = "message-bubble message-ai";
                aDiv.innerText = aiText;
                box.appendChild(aDiv);
                box.scrollTop = box.scrollHeight;
            } catch {
                const errDiv = document.createElement('div');
                errDiv.className = "message-bubble message-ai text-red-400";
                errDiv.innerText = "Error: Connection timeout.";
                box.appendChild(errDiv);
            }
        });

        // Modals
        function showModal(title, body, onConfirm) {
            document.getElementById('modal-title').innerText = title;
            document.getElementById('modal-body').innerText = body;
            document.getElementById('modal-confirm').onclick = onConfirm;
            document.getElementById('modal-container').classList.remove('hidden');
        }
        function closeModal() { document.getElementById('modal-container').classList.add('hidden'); }
    </script>
</body>
</html>
