    <script>
        // --- CONFIG ---
        const apiKey = ""; // Provided by env
        const firebaseConfig = JSON.parse(__firebase_config);
        firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
        const db = firebase.firestore();
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'presence_v7_v2';
        const dbPath = `artifacts/${appId}/public/data/presence`;

        let students = [];
        let currentPass = localStorage.getItem('app_pin_v7') || '1234';
        let isAuthenticating = false;
        let dbUnsubscribe = null;

        const showToast = (msg) => {
            const t = document.getElementById('status-toast');
            document.getElementById('toast-msg').innerText = msg;
            t.classList.add('visible');
            setTimeout(() => t.classList.remove('visible'), 3000);
        };

        // --- THEME ---
        window.toggleTheme = () => {
            const isDark = document.body.classList.toggle('dark');
            document.body.classList.toggle('light', !isDark);
            document.getElementById('theme-thumb').style.transform = isDark ? 'translateX(16px)' : 'translateX(0)';
            localStorage.setItem('presence_theme', isDark ? 'dark' : 'light');
        };
        if (localStorage.getItem('presence_theme') === 'light') toggleTheme();

        // --- NAVIGATION ---
        window.changePage = (id) => {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-link').forEach(n => n.classList.remove('active'));
            document.getElementById(`page-${id}`).classList.add('active');
            document.getElementById(`btn-${id}`).classList.add('active');
            document.getElementById('active-header').innerText = id === 'ai' ? 'Intelligence' : id.charAt(0).toUpperCase() + id.slice(1);
        };

        // --- AUTH ---
        async function validateLogin() {
            if (isAuthenticating) return;
            const input = document.getElementById('auth-pass').value;
            const err = document.getElementById('auth-error');
            const btn = document.getElementById('login-btn');
            
            if (input === currentPass) {
                isAuthenticating = true;
                err.classList.add('hidden');
                btn.disabled = true;
                btn.innerHTML = `<span class="loader"></span>`;
                
                try {
                    if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                        await auth.signInWithCustomToken(__initial_auth_token);
                    } else {
                        await auth.signInAnonymously();
                    }
                    document.getElementById('login-overlay').style.display = 'none';
                    document.getElementById('main-interface').classList.remove('hidden');
                    initDB();
                } catch (e) { 
                    isAuthenticating = false;
                    btn.disabled = false;
                    btn.innerHTML = 'Unlock';
                }
            } else {
                err.classList.remove('hidden');
                document.getElementById('auth-pass').value = '';
            }
        }

        // --- DB ---
        function initDB() {
            if (!auth.currentUser) return;
            if (dbUnsubscribe) dbUnsubscribe();
            const ref = db.collection(dbPath);
            dbUnsubscribe = ref.onSnapshot(s => {
                students = s.docs.map(d => ({ id: d.id, ...d.data() }));
                students.sort((a, b) => (b.ts || 0) - (a.ts || 0));
                render();
            });
        }

        async function addStudent() {
            const btn = document.getElementById('submit-btn');
            const n = document.getElementById('inp-name');
            const a = document.getElementById('inp-age');
            if (!n.value || !a.value || btn.disabled || !auth.currentUser) return;
            btn.disabled = true;
            btn.innerHTML = `<span class="loader"></span>`;
            try {
                await db.collection(dbPath).add({ 
                    name: n.value.trim(), 
                    age: parseInt(a.value), 
                    ts: Date.now(), 
                    time: new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit', second:'2-digit'}), 
                    dateLabel: new Date().toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) 
                });
                showToast("Entry Synced");
                n.value = ''; a.value = '';
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Submit Record';
            }
        }

        // --- AI LOGIC ---
        async function runAIAnalysis() {
            const out = document.getElementById('ai-output');
            const trigger = document.getElementById('ai-trigger');
            if (students.length === 0) {
                out.innerHTML = '<p class="text-red-400">Error: Insufficient data. Register subjects first.</p>';
                return;
            }

            trigger.disabled = true;
            out.innerHTML = '<div class="flex items-center gap-3 text-indigo-400"><span class="loader border-indigo-400"></span><span class="font-black uppercase text-[10px] tracking-widest animate-pulse">Scanning Database...</span></div>';

            const summary = students.map(s => `Subject: ${s.name}, Age: ${s.age}, Time: ${s.time}, Date: ${s.dateLabel}`).join('\n');
            const prompt = `Analyze this registration data and provide 3 key insights (Peak times, age trends, or volume). Keep it professional and technical. Data:\n${summary}`;

            try {
                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
                });
                const data = await response.json();
                const text = data.candidates?.[0]?.content?.parts?.[0]?.text || "Link timed out.";
                
                out.innerHTML = '';
                let i = 0;
                function typeWriter() {
                    if (i < text.length) {
                        out.innerHTML += text.charAt(i);
                        i++;
                        setTimeout(typeWriter, 5);
                    } else {
                        trigger.disabled = false;
                    }
                }
                typeWriter();
            } catch (e) {
                out.innerHTML = '<p class="text-red-400">Link Failure: AI module unreachable.</p>';
                trigger.disabled = false;
            }
        }

        // --- HELPERS ---
        window.viewDay = (date) => {
            const dayStudents = students.filter(s => s.dateLabel === date);
            document.getElementById('modal-date-title').innerText = date;
            const tbody = document.getElementById('modal-table-body');
            tbody.innerHTML = dayStudents.map(s => `
                <tr class="border-b border-white/5">
                    <td class="py-4 font-bold text-sm">${s.name}</td>
                    <td class="py-4 text-center text-slate-400 text-xs">${s.age}</td>
                    <td class="py-4 text-right font-mono text-xs text-indigo-400">${s.time}</td>
                </tr>`).join('');
            document.getElementById('day-modal').classList.remove('hidden');
        };

        window.closeDayModal = () => document.getElementById('day-modal').classList.add('hidden');

        window.deleteDay = async (date) => {
            const b = db.batch();
            students.filter(s => s.dateLabel === date).forEach(s => b.delete(db.collection(dbPath).doc(s.id)));
            await b.commit();
            showToast("Cycle Purged");
        };

        window.saveDay = (date) => {
            const d = students.filter(s => s.dateLabel === date);
            const csv = "Name,Age,Time\n" + d.map(e => `${e.name},${e.age},${e.time}`).join("\n");
            const link = document.createElement("a");
            link.href = 'data:text/csv;charset=utf-8,' + encodeURI(csv);
            link.download = `Presence_${date}.csv`;
            link.click();
        };

        window.deleteEntry = id => db.collection(dbPath).doc(id).delete().then(() => showToast("Purged"));
        window.manualWipe = async () => {
            const b = db.batch();
            students.forEach(s => b.delete(db.collection(dbPath).doc(s.id)));
            await b.commit();
        };

        function render() {
            const len = students.length;
            document.getElementById('stat-total').innerText = len.toString().padStart(2, '0');
            const perc = Math.min((len / 30) * 100, 100);
            document.getElementById('main-progress').style.width = perc + '%';
            document.getElementById('progress-val').innerText = Math.round(perc) + '%';

            const tbody = document.getElementById('table-body');
            tbody.innerHTML = students.length ? students.map(s => `
                <tr class="border-b border-white/5 hover:bg-indigo-500/5 transition-colors">
                    <td class="p-6 font-bold text-sm">${s.name}</td>
                    <td class="p-6 text-slate-400 text-xs">${s.age}</td>
                    <td class="p-6 text-indigo-400 font-mono text-xs">${s.time}</td>
                    <td class="p-6 text-right"><button onclick="deleteEntry('${s.id}')" class="text-slate-600 hover:text-red-500">×</button></td>
                </tr>`).join('') : '<tr><td colspan="4" class="p-12 text-center opacity-30 text-xs font-black uppercase tracking-widest">No Data</td></tr>';

            const groups = {};
            students.forEach(s => groups[s.dateLabel] = (groups[s.dateLabel] || 0) + 1);
            document.getElementById('day-groups').innerHTML = Object.keys(groups).sort((a,b) => new Date(b)-new Date(a)).map(d => `
                <div class="glass p-8 rounded-2xl border-t-4 border-indigo-600 shadow-lg flex flex-col">
                    <div class="text-[9px] font-black text-slate-500 uppercase mb-2">Cycle</div>
                    <div class="text-lg font-black mb-4">${d}</div>
                    <div class="mb-6"><span class="text-xs font-bold text-indigo-400 bg-indigo-500/10 px-3 py-1 rounded-full">${groups[d]} Records</span></div>
                    <div class="mt-auto grid grid-cols-3 gap-2">
                        <button onclick="viewDay('${d}')" class="bg-white/5 text-indigo-300 py-2 rounded-lg text-[9px] font-black uppercase">See</button>
                        <button onclick="saveDay('${d}')" class="bg-white/5 text-emerald-400 py-2 rounded-lg text-[9px] font-black uppercase">Save</button>
                        <button onclick="deleteDay('${d}')" class="bg-red-500/5 text-red-400 py-2 rounded-lg text-[9px] font-black uppercase">Del</button>
                    </div>
                </div>`).join('');
        }

        setInterval(() => document.getElementById('live-clock').innerText = new Date().toLocaleTimeString('en-GB'), 1000);
        document.getElementById('login-form').addEventListener('submit', e => { e.preventDefault(); validateLogin(); });
        document.getElementById('add-form').addEventListener('submit', e => { e.preventDefault(); addStudent(); });
    </script>
</body>
</html>
